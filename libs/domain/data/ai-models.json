	"agentSetups": [
		{
			"id": "writer_reviewer",
			"name": "Writer + Reviewer",
			"description": "One model writes, another reviews. Quality = average of both +10%",
			"requiredModels": 2,
			"unlockCondition": "ownedModels >= 3",
			"slots": [
				{
					"role": "writer",
					"label": "Writer"
				},
				{
					"role": "reviewer",
					"label": "Reviewer"
				}
			],
			"effects": {
				"locOutput": "writer.locPerSec",
				"quality": "(writer.quality + reviewer.quality) / 2 + 10",
				"flopsCost": "writer.flopsCost + reviewer.flopsCost"
			}
		},
		{
			"id": "swarm",
			"name": "Swarm",
			"description": "All owned models write in parallel. Raw throughput, average quality.",
			"requiredModels": 3,
			"unlockCondition": "ownedModels >= 3",
			"slots": "all_owned",
			"effects": {
				"locOutput": "sum(all.locPerSec)",
				"quality": "avg(all.quality)",
				"flopsCost": "sum(all.flopsCost)"
			}
		},
		{
			"id": "pipeline",
			"name": "Pipeline",
			"description": "Chain 3 models: draft → refine → optimize. Slow but high quality.",
			"requiredModels": 3,
			"unlockCondition": "ownedModels >= 3",
			"slots": [
				{
					"role": "drafter",
					"label": "Draft"
				},
				{
					"role": "refiner",
					"label": "Refine"
				},
				{
					"role": "optimizer",
					"label": "Optimize"
				}
			],
			"effects": {
				"locOutput": "min(all.locPerSec)",
				"quality": "max(all.quality) + 15",
				"flopsCost": "sum(all.flopsCost) * 0.8"
			}
		},
		{
			"id": "tournament",
			"name": "Tournament",
			"description": "Two models race, best output kept. Fast and clean, but wasteful.",
			"requiredModels": 2,
			"unlockCondition": "ownedModels >= 3",
			"slots": [
				{
					"role": "contestant_a",
					"label": "Model A"
				},
				{
					"role": "contestant_b",
					"label": "Model B"
				}
			],
			"effects": {
				"locOutput": "max(a.locPerSec, b.locPerSec)",
				"quality": "max(a.quality, b.quality)",
				"flopsCost": "(a.flopsCost + b.flopsCost) * 1.5"
			}
		}
	]
